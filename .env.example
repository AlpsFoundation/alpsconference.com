# --- Astro: browser calls this URL (add to your real .env; restart `bun run dev`) ---
PUBLIC_NEWSLETTER_API_URL=http://127.0.0.1:8080/api/newsletter-subscribe.php

# Infomaniak API token (Manager → API / OAuth; scope: newsletter)
INFOMANIAK_TOKEN=

# Newsletter domain ID (integer from Infomaniak Manager → Newsletter)
INFOMANIAK_NEWSLETTER_DOMAIN=

# Optional: comma-separated group IDs and/or group names (see API "groups" body param)
# INFOMANIAK_NEWSLETTER_GROUPS=1234,ALPS 2026

# Browser CORS: comma-separated origins (exact scheme/host/port the browser sends as Origin)
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:4322,https://next.alps.foundation,https://alps.foundation,https://alpsconference.com

# Set to 1 while debugging (extra JSON "debug" on errors + request line on each hit)
# NEWSLETTER_DEBUG=1
