# Deny HTTP access to environment files (e.g. copied into dist on build)
<IfModule mod_authz_core.c>
    <FilesMatch "^\.env($|\.)">
        Require all denied
    </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
    <FilesMatch "^\.env($|\.)">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>
